# ============================================================
# media-transcriber Agent 环境变量模板
# ============================================================
# 使用方法：
#   1. 复制本文件为 .env（cp .env.example .env）
#   2. 填入真实凭据
#   3. .env 文件不要提交到 git（已在 .gitignore 中忽略）
#
# 安全提醒（参考小D 第 6 节 + 第 10 节）：
#   - 不要复制别人的 app secret
#   - 不要把 token、secret 写入聊天或文档
#   - 任何凭据都不能进入聊天和文档
# ============================================================

# ============================================================
# LLM 后端 — 智谱 GLM（推荐，国内直连免费档可用）
# ============================================================
# 获取地址：https://open.bigmodel.cn/
#
# 方式 B（推荐）：通用 OpenAI 兼容接入
#   provider: auto + base_url 指向智谱 OpenAI 兼容端点
#   优势：切换 LLM 后端时只需改 base_url 和 model，不用改代码
OPENAI_API_KEY=your_zhipu_api_key_here
OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
#
# 方式 A（向后兼容）：智谱 GLM 原生方式
# GLM_API_KEY=your_zhipu_api_key_here
# GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# 备选 LLM 后端（按需启用，三选一即可）
# --- OpenRouter（200+ 模型，国际推荐）---
# 获取地址：https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-your_key_here

# --- Anthropic Claude（提纯质量最高，需代理）---
# 获取地址：https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-your_key_here

# --- OpenAI（通用，需代理）---
# 获取地址：https://platform.openai.com/
# OPENAI_API_KEY=sk-your_key_here

# ============================================================
# 飞书 Bot / App 配置（Phase 2+ 启用）
# ============================================================
# 创建步骤：
#   1. 飞书开放平台 → 创建企业自建应用
#   2. 添加能力：机器人
#   3. 权限管理：开通 im:message, im:message.group_at_msg,
#      im:message.p2p_msg, im:message:send_as_bot
#   4. 事件订阅：添加 im.message.receive_v1
#   5. 复制 App ID + App Secret
# 详细配置参考知识库：02-platform-integrations/01-feishu-bot.md
FEISHU_APP_ID=your_feishu_app_id_here
FEISHU_APP_SECRET=your_feishu_app_secret_here
FEISHU_DOMAIN=feishu

# 你的飞书用户 ID（用于文档协作者授权）
# 获取方式：飞书个人主页 → 右上角更多 → 获取 ID
FEISHU_USER_ID=your_feishu_user_id_here

# 飞书文件夹 token（可选，指定文档创建位置）
# 获取方式：打开飞书云文档指定文件夹 → URL 中的 token 参数
# FEISHU_FOLDER_TOKEN=your_folder_token_here

# ============================================================
# Phase 3：飞书 Bot 触发配置
# ============================================================
# WebSocket 长连接模式（无需公网 IP，本地直接跑）
# 权限策略
FEISHU_ALLOW_ALL_USERS=true        # 是否允许所有用户触发（true/false）
FEISHU_DM_POLICY=open              # 私聊策略：open（所有人可用）/ restrict
FEISHU_GROUP_POLICY=open           # 群聊策略：open / restrict

# 管理员白名单（可选，逗号分隔的 open_id；ALLOW_ALL_USERS=false 时生效）
# 格式：ou_xxxxxxxx,ou_yyyyyyyy
# FEISHU_ADMIN_IDS=ou_xxxxxxxx,ou_yyyyyyyy

# ============================================================
# 下载配置（B 站反爬 / 多平台 cookies）
# ============================================================
# B 站近期升级反爬，未登录会返回 412 错误，需配置 cookies
# 方式 1：cookies 文件路径（Netscape 格式，推荐）
# 导出教程见 docs/troubleshooting.md 坑 31
# COOKIES_FILE=./config/cookies.txt

# 方式 2：从浏览器读取（如 chrome/edge/firefox）
# 注意：新版 Chrome 加密了 cookies，此方式可能失效
# COOKIES_FROM_BROWSER=chrome

# 权限策略（关键：不开会被拒收消息）
FEISHU_ALLOW_ALL_USERS=true
GATEWAY_ALLOW_ALL_USERS=true
FEISHU_DM_POLICY=open
FEISHU_GROUP_POLICY=open

# ============================================================
# ASR 配置（faster-whisper）
# ============================================================
# 模型缓存目录（默认 ~/.cache/huggingface）
WHISPER_CACHE_DIR=./.cache/whisper

# ============================================================
# 代理配置（如需访问 YouTube/抖音等海外平台）
# ============================================================
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# ============================================================
# 日志配置
# ============================================================
LOG_LEVEL=INFO                       # DEBUG / INFO / WARNING / ERROR
LOG_DIR=./logs
