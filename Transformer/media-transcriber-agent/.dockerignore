# Docker 构建忽略文件（减少构建上下文体积，加速构建）
# 排除所有运行时生成的、非源码的文件

# Python 虚拟环境（容器内自己装）
venv/
.venv/
env/

# Python 缓存
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
.pytest_cache/
.mypy_cache/

# 运行时数据（运行时挂载 volume，不进镜像）
tmp/
output/
logs/
*.log

# 模型缓存（运行时挂载 volume）
.cache/
.modelscope/

# 配置文件（含敏感信息，运行时挂载）
# 注意：.env 和 config/ 不进镜像，通过 volume 挂载
.env
.env.*
config/

# 开发工具配置
.vscode/
.idea/
.git/
.gitignore
.github/

# 文档（不影响运行）
docs/
*.md
!prompts/**/*.md

# 系统文件
.DS_Store
Thumbs.db
desktop.ini

# 临时脚本（一次性脚本，不需要进镜像）
tmp/
*.tmp
*.bak

# Docker 自身文件（避免循环引用）
Dockerfile
docker-compose.yml
.dockerignore
